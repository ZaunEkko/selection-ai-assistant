{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Selection AI Assistant",
  "version": "0.3.1",
  "identifier": "com.selection-ai-assistant.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Selection AI Assistant",
        "width": 900,
        "height": 700,
        "resizable": true,
        "visible": false
      },
      {
        "label": "floating-button",
        "title": "Mini Action Bar",
        "width": 244,
        "height": 44,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "replacement-preset",
        "title": "Replacement Preset",
        "width": 420,
        "height": 78,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "ai-panel",
        "title": "AI Assistant",
        "width": 520,
        "height": 620,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "source-text",
        "title": "Selected Text",
        "width": 360,
        "height": 620,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "translate-result",
        "title": "Translate Result",
        "width": 320,
        "height": 180,
        "minWidth": 260,
        "minHeight": 140,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "screenshot-overlay",
        "title": "Screenshot Translate",
        "width": 800,
        "height": 600,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'",
      "devCsp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:5173 ws://localhost:5173; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
