{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Selection AI Assistant",
  "version": "0.2.0",
  "identifier": "com.selection-ai-assistant.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Selection AI Assistant",
        "width": 900,
        "height": 700,
        "resizable": true,
        "visible": false
      },
      {
        "label": "floating-button",
        "title": "Mini Action Bar",
        "width": 244,
        "height": 44,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "replacement-preset",
        "title": "Replacement Preset",
        "width": 260,
        "height": 92,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "ai-panel",
        "title": "AI Assistant",
        "width": 520,
        "height": 620,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "source-text",
        "title": "Selected Text",
        "width": 360,
        "height": 620,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      },
      {
        "label": "translate-result",
        "title": "Translate Result",
        "width": 320,
        "height": 180,
        "minWidth": 260,
        "minHeight": 140,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
