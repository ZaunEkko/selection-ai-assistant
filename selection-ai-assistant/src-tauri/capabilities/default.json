{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Allow local app windows to use the Tauri APIs required by the assistant UI.",
  "windows": ["main", "floating-button", "replacement-preset", "ai-panel", "source-text", "translate-result"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-start-resize-dragging",
    "opener:default"
  ]
}
